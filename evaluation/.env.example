# Judge API configuration (required for scoring).
# Single-judge fallback, used only when JUDGE_MODELS below is empty:
JUDGE_API_KEY="sk-xxx"
JUDGE_API_BASE="https://api.openai.com/v1"
JUDGE_MODEL_NAME="gpt-5.1"

# Judge ENSEMBLE (default for the dashboard "Score" button and rescore.py).
# Comma-separated OpenRouter slugs scored over a shared base + key; the per-axis
# mean and inter-judge std power the leaderboard error bars. Edit this list to
# change the evaluator models. Leave empty to use the single judge above.
JUDGE_MODELS="anthropic/claude-opus-4.8,openai/gpt-5.1,google/gemini-3-pro"
OPENROUTER_API_BASE="https://openrouter.ai/api/v1"
OPENROUTER_API_KEY="sk-or-xxx"   # or set JUDGE_ENSEMBLE_API_KEY / JUDGE_ENSEMBLE_API_BASE

# Evaluated model API configuration (required by rcb-eval YAML examples)
AGENT_API_KEY="sk-agent-xxx"
AGENT_API_BASE="https://your-agent-api.example/v1"
AGENT_MODEL_NAME="gpt-5.4"

# ResearchHarness tool configuration (required for real rcb-eval runs)
# These are inherited by the installed researchharness package for web search,
# web fetch, and PDF reading. Do not set WORKSPACE_ROOT here; RCB controls the
# batch workspace layout.
SERPER_KEY="serper-xxx"
JINA_KEY="jina-xxx"
MINERU_TOKEN="mineru-xxx"
